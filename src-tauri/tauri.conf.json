{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Quark",
  "version": "0.1.2",
  "identifier": "de.quark.app",
  "build": {
    "frontendDist": "../src/frontend/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd src/frontend && npm run dev",
    "beforeBuildCommand": "cd src/frontend && npm run build"
  },
  "app": {
    "windows": [],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/nicolettas-muggelbude/quark/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDhEMjY3OTM2N0U5QUNFN0UKUldSK3pwcCtObmttald4Q0FpSWdCT1B5VGhHUC8vbHRvazYzYUZ5bklEOG1IYzVaYmV2QWVGRGUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["appimage", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/256x256.png",
      "icons/icon.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
